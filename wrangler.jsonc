{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bakeryos",
  // Worker entry point — handles /api/* routes and delegates everything else to ASSETS
  "main": "worker.ts",
  "compatibility_date": "2026-04-10",
  "kv_namespaces": [
    { "binding": "BAKERY_DATA", "id": "0e228ea8873845bea266cc68e3e5669f" }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  // Serves the Vite build output as a static SPA.
  // Requests that don't match a file fall back to index.html.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
  // Secrets (never committed here — set via `wrangler secret put`):
  //   ANTHROPIC_API_KEY
}
