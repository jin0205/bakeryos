# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# Shared auth token between the browser and the Cloudflare Worker.
# Must match the BAKERY_API_TOKEN Cloudflare secret set via:
#   wrangler secret put BAKERY_API_TOKEN
VITE_BAKERY_API_TOKEN=your-token-here
